<!DOCTYPE html>
<html lang="so">
<head>
    <meta charset="UTF-8">
    <title>Dashboard - BIILE ACADEMY</title>
    <style>
        body { font-family: Arial, sans-serif; margin: 0; background: #f4f7f6; }
        .header { background: #007bff; color: white; padding: 20px; display: flex; justify-content: space-between; align-items: center; }
        .container { max-width: 1000px; margin: 30px auto; padding: 20px; }
        .grid { display: grid; grid-template-columns: 2fr 1fr; gap: 20px; }
        .card { background: white; padding: 20px; border-radius: 8px; box-shadow: 0 0 10px rgba(0,0,0,0.05); margin-bottom: 20px; }
        h3 { border-bottom: 2px solid #f4f7f6; padding-bottom: 10px; color: #333; }
        .logout-btn { background: red; color: white; padding: 10px 15px; text-decoration: none; border-radius: 4px; }
        .status-paid { color: green; font-weight: bold; }
        .status-due { color: red; font-weight: bold; }
    </style>
</head>
<body>

    <div class="header">
        <h1>BIILE ACADEMY Portal</h1>
        <a href="/logout" class="logout-btn">Ka Bax (Logout)</a>
    </div>

    <div class="container">
        <h2>Soo dhawoow ardaygaygii </h2>
        
        <div class="grid">
            <!-- Qaybta Macluumaadka Ardayga iyo Duruusta -->
            <div>
                <div class="card">
                    <h3>Astaamaha Ardayga</h3>
                    <p><strong>Magaca Ardayga:</strong> <%= arday.magac %></p>
                    <p><strong>Username:</strong> <%= arday.username %></p>
                </div>

                <div class="card">
                    <h3>Duruusta & Koorsooyinka</h3>
                    <p><strong>Koorsada Aad Ku Jirto:</strong> <span style="color:#007bff;"><%= arday.koorso %></span></p>
                    <h4>Casharada kuu furan:</h4>
                    <ul>
                        <% arday.casharo.forEach(function(cashar) { %>
                            <li><%= cashar %></li>
                        <% }); %>
                    </ul>
                </div>
            </div>

            <!-- Qaybta Lacagaha -->
            <div>
                <div class="card">
                    <h3>Xisaabta & Lacagaha</h3>
                    <p><strong>Bisha:</strong> <%= arday.lacagaha.bisha %></p>
                    <p><strong>Cadadka:</strong> <%= arday.lacagaha.cadadka %></p>
                    <p><strong>Xaaladda Lacagta:</strong> 
                        <span class="<%= arday.lacagaha.status === 'La Bixiyay' ? 'status-paid' : 'status-due' %>">
                            <%= arday.lacagaha.status %>
                        </span>
                    </p>
                </div>
            </div>
        </div>
    </div>

</body>
</html>
